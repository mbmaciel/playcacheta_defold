local function set_exit_confirm_visible(self, enabled)
    self.exit_confirm_open = enabled and true or false
    gui.set_enabled(self.exit_overlay, self.exit_confirm_open)
    gui.set_enabled(self.exit_shadow, self.exit_confirm_open)
    gui.set_enabled(self.exit_panel, self.exit_confirm_open)
    gui.set_enabled(self.exit_topbar, self.exit_confirm_open)
    gui.set_enabled(self.exit_bdr, self.exit_confirm_open)
    gui.set_enabled(self.exit_title, self.exit_confirm_open)
    gui.set_enabled(self.exit_sub, self.exit_confirm_open)
    gui.set_enabled(self.btn_exit_confirm, self.exit_confirm_open)
    gui.set_enabled(self.btn_exit_cancel, self.exit_confirm_open)
end

local function set_post_win_prompt_visible(self, enabled, entry_fee, player_won, opponent_name)
    self.post_win_prompt_open = enabled and true or false
    gui.set_enabled(self.post_win_overlay, self.post_win_prompt_open)
    gui.set_enabled(self.post_win_shadow, self.post_win_prompt_open)
    gui.set_enabled(self.post_win_panel, self.post_win_prompt_open)
    gui.set_enabled(self.post_win_topbar, self.post_win_prompt_open)
    gui.set_enabled(self.post_win_bdr, self.post_win_prompt_open)
    gui.set_enabled(self.post_win_title, self.post_win_prompt_open)
    gui.set_enabled(self.post_win_sub, self.post_win_prompt_open)
    gui.set_enabled(self.post_win_hint, self.post_win_prompt_open)
    gui.set_enabled(self.btn_post_win_continue, self.post_win_prompt_open)
    gui.set_enabled(self.lbl_post_win_continue, self.post_win_prompt_open)
    gui.set_enabled(self.btn_post_win_leave, self.post_win_prompt_open)
    gui.set_enabled(self.lbl_post_win_leave, self.post_win_prompt_open)
    if self.post_win_prompt_open then
        local fee = tonumber(entry_fee) or 5
        if player_won == false then
            gui.set_text(self.post_win_title, tostring(opponent_name or "AdversĂˇrio") .. " venceu")
            gui.set_text(self.post_win_sub, "Deseja iniciar um novo jogo ou sair da sala?")
        else
            gui.set_text(self.post_win_title, "VocĂŞ venceu!")
            gui.set_text(self.post_win_sub, "Quer continuar na sala aguardando outro jogador?")
        end
        gui.set_text(self.lbl_post_win_continue, "Novo jogo")
        gui.set_text(self.lbl_post_win_leave, "Sair")
        gui.set_text(self.post_win_hint, "Novo jogo inicia com nova entrada de " .. fee .. " fichas.")
    end
end

local function set_waiting_room_visible(self, enabled)
    self.waiting_room_open = enabled and true or false
    if self.waiting_room_open then
        self.waiting_room_time = 0
    end
    gui.set_enabled(self.waiting_overlay, self.waiting_room_open)
    gui.set_enabled(self.waiting_panel, self.waiting_room_open)
    gui.set_enabled(self.waiting_topbar, self.waiting_room_open)
    gui.set_enabled(self.waiting_bdr, self.waiting_room_open)
    gui.set_enabled(self.waiting_title, self.waiting_room_open)
    gui.set_enabled(self.waiting_info, self.waiting_room_open)
    gui.set_enabled(self.waiting_meta, self.waiting_room_open)
end

local function update_waiting_room_text(self)
    local dots = string.rep(".", (math.floor(self.waiting_room_time * 2) % 4))
    gui.set_text(self.waiting_info, "Aguardando entrada de outro jogador" .. dots)
    gui.set_text(self.waiting_meta,
        "Jogadores na sala: " .. tostring(self.waiting_players_count or 1) ..
        "  |  Status: " .. tostring(self.waiting_room_status or "waiting"))
end

local function refresh_buttons(self, data)
    local pending_by_cpu = data.pending and data.called_by == "cpu"
    local hand_over      = data.hand_over

    gui.set_enabled(self.btn_truco,  data.can_call and not hand_over)
    gui.set_enabled(self.btn_accept, pending_by_cpu)
    gui.set_enabled(self.btn_raise,  pending_by_cpu and data.can_raise)
    gui.set_enabled(self.btn_run,    pending_by_cpu)
    gui.set_enabled(self.btn_next,   hand_over == true)
end

local function update_info(self)
    gui.set_text(self.info_node,
        'Vira:'..self.last_vira_id..' Man:'..self.last_manilha..
        ' | M'..self.last_round..' '..self.last_pts..'pt '..
        self.last_tricks_p..'Ă—'..self.last_tricks_c)
end

function on_message(self, message_id, message, sender)
    if message_id == hash('set_status') then
        gui.set_text(self.status_node, message.text or '')

    elseif message_id == hash('set_scores') then
        self.player_name = tostring(message.player_name or self.player_name or "VocĂŞ")
        self.opponent_name = tostring(message.opponent_name or self.opponent_name or "AdversĂˇrio")
        gui.set_text(self.score_node,
            self.player_name..': '..tostring(message.player_score or 0)..
            ' | '..self.opponent_name..': '..tostring(message.cpu_score or 0))

    elseif message_id == hash('set_tricks') then
        self.last_tricks_p = message.player_tricks or 0
        self.last_tricks_c = message.cpu_tricks or 0
        update_info(self)

    elseif message_id == hash('set_truco_state') then
        self.last_pts = message.hand_points or 1
        update_info(self)
        self.last_truco = message
        refresh_buttons(self, message)

    elseif message_id == hash('set_vira_info') then
        self.last_vira_id = tostring(message.vira_id or '?')
        self.last_manilha = tostring(message.manilha_val or '?')
        self.last_round   = message.round or 1
        update_info(self)

    elseif message_id == hash('set_hand_over') then
        local can_next = (message.hand_over == true) and (message.game_over ~= true) and
            (not self.post_win_prompt_open) and (not self.waiting_room_open)
        gui.set_enabled(self.btn_next, can_next)
        if message.hand_over then
            gui.set_enabled(self.btn_truco,  false)
            gui.set_enabled(self.btn_accept, false)
            gui.set_enabled(self.btn_raise,  false)
            gui.set_enabled(self.btn_run,    false)
        end

    elseif message_id == hash('show_post_match_prompt') then
        set_waiting_room_visible(self, false)
        set_post_win_prompt_visible(
            self,
            true,
            message.entry_fee,
            message.player_won ~= false,
            message.opponent_name
        )

    elseif message_id == hash('set_waiting_room') then
        set_post_win_prompt_visible(self, false)
        set_waiting_room_visible(self, message.enabled == true)
        if self.waiting_room_open then
            update_waiting_room_text(self)
        end

    elseif message_id == hash('set_waiting_room_info') then
        self.waiting_players_count = tonumber(message.players_count) or self.waiting_players_count or 1
        self.waiting_room_status = tostring(message.status or self.waiting_room_status or "waiting")
        if self.waiting_room_open then
            update_waiting_room_text(self)
        end
    end
end

function update(self, dt)
    if self.waiting_room_open then
        self.waiting_room_time = (self.waiting_room_time or 0) + dt
        update_waiting_room_text(self)
    end
end

function on_input(self, action_id, action)
    if not ((action_id == hash('mouse_press') or action_id == hash('touch')) and action.pressed) then
        return false
    end
    local x, y = action.x, action.y

    if self.post_win_prompt_open then
        if gui.pick_node(self.btn_post_win_continue, x, y) then
            set_post_win_prompt_visible(self, false)
            msg.post('/controller#controller_script', 'player_keep_room_after_match')
            return true
        end
        if gui.pick_node(self.btn_post_win_leave, x, y) then
            set_post_win_prompt_visible(self, false)
            msg.post('/controller#controller_script', 'player_leave_after_match')
            local token, user = Session.load()
            if token and user then
                API.set_token(token)
                msg.post('/lobby#lobby_gui', 'show_lobby', {user=user, token=token})
            else
                msg.post('/title#title_gui', 'show_title')
            end
            return true
        end
        return true
    end

    if self.waiting_room_open then
        return true
    end

    if self.exit_confirm_open then
        if gui.pick_node(self.btn_exit_confirm, x, y) then
            set_exit_confirm_visible(self, false)
            msg.post('/controller#controller_script', 'player_abandoned_match')
            local token, user = Session.load()
            if token and user then
                API.set_token(token)
                msg.post('/lobby#lobby_gui', 'show_lobby', {user=user, token=token})
            else
                msg.post('/title#title_gui', 'show_title')
            end
            return true
        end
        if gui.pick_node(self.btn_exit_cancel, x, y) then
            set_exit_confirm_visible(self, false)
            return true
        end
        return true
    end

    if gui.pick_node(self.btn_sair, x, y) then
        set_exit_confirm_visible(self, true)
        return true
    end

    if gui.is_enabled(self.btn_truco) and gui.pick_node(self.btn_truco, x, y) then
        msg.post('/controller#controller_script', 'ui_truco')
        return true
    end
    if gui.is_enabled(self.btn_accept) and gui.pick_node(self.btn_accept, x, y) then
        msg.post('/controller#controller_script', 'ui_accept')
        return true
    end
    if gui.is_enabled(self.btn_raise) and gui.pick_node(self.btn_raise, x, y) then
        msg.post('/controller#controller_script', 'ui_raise')
        return true
    end
    if gui.is_enabled(self.btn_run) and gui.pick_node(self.btn_run, x, y) then
        msg.post('/controller#controller_script', 'ui_run')
        return true
    end
    if gui.is_enabled(self.btn_next) and gui.pick_node(self.btn_next, x, y) then
        msg.post('/controller#controller_script', 'ui_next_hand')
        return true
    end

    return false
end
